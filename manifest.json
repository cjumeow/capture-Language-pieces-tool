{
  "manifest_version": 3,
  "name": "English Piece Collector",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["getContext.js", "content.js"]
    }
  ],
  "commands": {
    "save-piece-command": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "select language pieces"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
